<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sanctuaire Ex Materia</title>
<meta name="theme-color" content="#0b0b12">
<style>
/* ============ TOKENS / RESET ============ */
*,*:before,*:after{box-sizing:border-box}
:root{
  --bg:#03030a; --line:#ffffff16; --glass:#ffffff0d;
  --gold:#d8b86a; --gold2:#f6e7b0; --soft:#ececf7; --muted:#c9c9db;
  --blue:#2435ff; --glow:#2836d0;
  --rad:18px; --shadow:0 22px 60px rgba(0,0,0,.55);
}
html,body{height:100%;scroll-behavior:smooth}
body{
  margin:0; font-family:ui-sans-serif,system-ui,Segoe UI,Roboto,Arial;
  color:var(--soft);
  background:radial-gradient(1200px 700px at 50% -8%,#151528,#000 68%) fixed;
  overflow-x:hidden;
}
a{color:inherit;text-decoration:none}
code{background:#ffffff12;padding:2px 6px;border-radius:6px}

/* ============ BACKGROUND CANVAS ============ */
#stars,#nebula{position:fixed;inset:0;z-index:-2}
#grain{position:fixed;inset:0;z-index:-1;pointer-events:none;opacity:.06;
  background-image:url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="140" height="140"><filter id="n"><feTurbulence type="fractalNoise" baseFrequency=".9" numOctaves="2" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23n)"/></svg>');
  mix-blend-mode:screen}

/* ============ HEADER / NAV ============ */
header{position:sticky;top:0;z-index:10;backdrop-filter:blur(12px);
  background:linear-gradient(to bottom,rgba(0,0,0,.55),rgba(0,0,0,.12));
  border-bottom:1px solid var(--line)
}
.head{max-width:1180px;margin:auto;padding:14px 18px;display:flex;gap:12px;align-items:center;justify-content:space-between}
.brand{display:flex;gap:12px;align-items:center}
.badge{width:42px;height:42px;border-radius:50%;display:grid;place-items:center;
  background:linear-gradient(180deg,#141438,#070712);
  border:1px solid var(--line); box-shadow:inset 0 0 14px #ffffff1a, 0 0 38px #1d2bd055}
.brand h1{margin:0;font-size:20px;color:var(--gold);letter-spacing:.6px}
nav{display:flex;gap:10px;flex-wrap:wrap}
nav a{padding:10px 14px;border:1px solid var(--line);border-radius:999px;background:#0a0a18a3;font-weight:700;font-size:14px}
nav a:hover{border-color:#ffffff55;transform:translateY(-1px);box-shadow:0 12px 26px #0008}

/* ============ LAYOUT / CARDS ============ */
.section{max-width:1180px;margin:auto;padding:72px 18px}
.card,.tile{
  padding:22px;border-radius:var(--rad);border:1px solid var(--line);
  background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.02));
  box-shadow:var(--shadow)
}
h2{color:var(--gold);margin:0 0 12px}
.small{color:var(--muted);font-size:14px}
.grid-2{display:grid;gap:18px;grid-template-columns:1fr}
@media(min-width:900px){.grid-2{grid-template-columns:1.05fr .95fr}}
hr{border:0;border-top:1px solid var(--line);opacity:.7;margin:24px 0}

/* ============ HERO / SIGIL ============ */
.hero{text-align:center;padding-top:86px}
.hero h3{margin:8px 0 0;color:#e8e8f5cc;font-weight:500}
.cta{display:inline-block;margin:14px auto 6px;padding:12px 18px;border-radius:12px;
  background:linear-gradient(135deg,#1a214f,#0c0f2a);color:#fff;font-weight:800;border:1px solid #ffffff33;
  box-shadow:0 18px 36px rgba(0,0,0,.45)}
.cta:hover{transform:translateY(-1px);box-shadow:0 22px 44px rgba(0,0,0,.62)}
.sigil-wrap{display:grid;place-items:center;margin:6px auto 16px}
.sigil{width:min(170px,38vw);aspect-ratio:1/1;filter:drop-shadow(0 0 22px #2836d088)}
.sigil .ring{stroke:url(#g);stroke-width:2;fill:none}
.sigil .mark{fill:url(#g)}
@keyframes spin{to{transform:rotate(360deg)}}
.spin{animation:spin 22s linear infinite}

/* ============ REVEAL on SCROLL ============ */
.reveal{opacity:0;transform:translateY(16px);transition:.6s ease}
.reveal.show{opacity:1;transform:none}

/* ============ ILLUSTRATIONS TIMELINE ============ */
.band{
  display:grid;grid-template-rows:auto 120px;gap:10px
}
.scroller{display:flex;gap:10px;overflow-x:auto;padding-bottom:6px}
.scroller img{height:120px;width:auto;border-radius:12px;flex:0 0 auto;border:1px solid var(--line)}
.stage{
  position:relative;border-radius:14px;overflow:hidden;border:1px solid var(--line);
  background:#05050f;height:min(34vw,340px);display:grid;place-items:center
}
.stage img, .stage video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .6s ease}
.stage img.active,.stage video.active{opacity:1}

/* ============ FOOTER ============ */
footer{border-top:1px solid var(--line);padding:28px 18px;text-align:center;color:#cfcfe9a6;font-size:13px}
.fab{position:fixed;right:16px;bottom:16px;border-radius:14px;background:linear-gradient(135deg,#1d235a,#0c0f2a);
  color:#fff;border:1px solid #ffffff33;padding:12px 14px;font-weight:800;box-shadow:0 16px 32px rgba(0,0,0,.55)}
.fab:hover{transform:translateY(-1px)}
</style>
</head>
<body>
<!-- Background -->
<canvas id="stars"></canvas>
<canvas id="nebula"></canvas>
<div id="grain"></div>

<!-- HEADER -->
<header>
  <div class="head">
    <div class="brand">
      <div class="badge" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24">
          <defs><linearGradient id="gmini" x1="0" x2="1"><stop offset="0" stop-color="#f6e7b0"/><stop offset="1" stop-color="#d8b86a"/></linearGradient></defs>
          <circle cx="12" cy="12" r="9" stroke="url(#gmini)" stroke-width="1.4" fill="none"/>
          <path d="M12 6v12M6 12h12" stroke="url(#gmini)" stroke-width="1.4"/>
        </svg>
      </div>
      <h1>Sanctuaire Ex Materia</h1>
    </div>
    <nav>
      <a href="#livre">Livre du Tout</a>
      <a href="#nutrition">Nutrition</a>
      <a href="#pineale">Pinéale</a>
      <a href="#rituel">Rituel</a>
    </nav>
  </div>
</header>

<!-- HERO -->
<section class="section hero">
  <div class="sigil-wrap reveal">
    <svg class="sigil" viewBox="0 0 220 220">
      <defs><linearGradient id="g" x1="0" x2="1"><stop offset="0" stop-color="#f6e7b0"/><stop offset="1" stop-color="#d8b86a"/></linearGradient></defs>
      <circle class="ring spin" cx="110" cy="110" r="96"/>
      <circle class="ring" cx="110" cy="110" r="68" opacity=".55"/>
      <path class="mark" d="M110 36 l12 22 h26 l-21 16 8 24 -25 -14 -25 14 8-24 -21-16 h26z" opacity=".95"/>
    </svg>
  </div>
  <h2 class="reveal">Un espace sacré pour élever ta fréquence</h2>
  <h3 class="reveal">La Voix du Tout te remet les clefs — Souviens-toi.</h3>
  <a class="cta reveal" href="#livre">Entrer dans le Livre du Tout</a>

  <div class="grid-2" style="max-width:980px;margin:28px auto">
    <div class="card reveal">
      <h2>🎙️ Voix du Tout</h2>
      <p class="small">Ajoute ton audio pour immersion totale. Mets ton fichier ici : <code>assets/voix_du_tout.mp3</code> puis dé-commente la ligne ci-dessous.</p>
      <!-- <audio controls src="assets/voix_du_tout.mp3" style="width:100%"></audio> -->
    </div>
    <div class="card reveal">
      <h2>🎥 Avatar parlant</h2>
      <p class="small">Place la vidéo de ton avatar animé ici : <code>assets/avatar_talking.mp4</code> puis dé-commente.</p>
      <!-- <video controls playsinline src="assets/avatar_talking.mp4" style="width:100%;border-radius:12px"></video> -->
    </div>
  </div>
</section>

<!-- LIVRE DU TOUT -->
<section id="livre" class="section">
  <div class="grid-2">
    <div class="tile reveal">
      <h2>📜 Le Livre du Tout — Clé du jour</h2>
      <p class="small"><em>« L’énergie suit l’attention. Là où tu poses ton regard, là s’écoule ta destinée. »</em></p>
      <hr>
      <p><b>Loi de Vibration</b> — Tout est vibration. Ajuste ta pensée, ajuste le monde.</p>
      <p><b>Loi de Correspondance</b> — Ce qui est en haut est comme ce qui est en bas.</p>
      <p><b>Loi de Polarité</b> — Les opposés sont deux faces d’une seule réalité.</p>
      <p><b>Loi du Rythme</b> — Inspire/expire — marée de l’univers. Danse avec elle.</p>
    </div>

    <!-- Bande d’illustrations synchronisée -->
    <div class="tile reveal">
      <h2>🖼 Illustrations du “dire du Tout” (synchro)</h2>
      <div class="band">
        <div class="stage" id="stage">
          <!-- Images affichées en grand (elles s’alternent automatiquement avec les timecodes JS) -->
          <img src="assets/illus/1.jpg" alt="Illustration 1 (ex. marionnette)" class="active">
          <img src="assets/illus/2.jpg" alt="Illustration 2 (ex. cosmos)">
          <img src="assets/illus/3.jpg" alt="Illustration 3 (ex. flux lumineux)">
          <!-- Tu peux aussi mettre une vidéo courte :
          <video src="assets/illus/clip1.mp4" muted loop></video> -->
        </div>
        <div class="scroller">
          <img src="assets/illus/1.jpg" alt="">
          <img src="assets/illus/2.jpg" alt="">
          <img src="assets/illus/3.jpg" alt="">
        </div>
        <p class="small">Ajoute tes images dans <code>assets/illus/</code>. Les changements suivent les timecodes plus bas.</p>
      </div>
    </div>
  </div>
</section>

<!-- NUTRITION -->
<section id="nutrition" class="section">
  <div class="grid-2">
    <div class="tile reveal">
      <h2>🌿 Nutrition Sacrée</h2>
      <ul class="small" style="margin-top:8px">
        <li><b>Cacao cru</b> — ouverture du cœur</li>
        <li><b>Spiruline</b> — oxygène le corps subtil</li>
        <li><b>Chia</b> — stabilité énergétique</li>
        <li><b>Eau structurée</b> — clarté de résonance</li>
      </ul>
      <p class="small"><b>À éviter :</b> sucre raffiné, fluor, alcool.</p>
    </div>
    <div class="tile reveal">
      <h2>🎶 Fond vibratoire</h2>
      <p class="small">Place un drone subtil : <code>assets/drone_cosmos.mp3</code> puis dé-commente ci-dessous.</p>
      <!-- <audio controls loop src="assets/drone_cosmos.mp3" style="width:100%"></audio> -->
    </div>
  </div>
</section>

<!-- PINÉALE -->
<section id="pineale" class="section">
  <div class="grid-2">
    <div class="tile reveal">
      <h2>🔮 Glande Pinéale — Activation</h2>
      <p class="small">Respiration 4‑4‑6 (7 cycles) — Silence 11 min — Son 111 Hz (très léger).</p>
      <p class="small">Attention douce au point entre les sourcils — observe sans forcer.</p>
    </div>
    <div class="tile reveal">
      <h2>🗝️ Mot sacré</h2>
      <p class="small">Choisis un mot : <b>Paix</b>, <b>Clarté</b>, <b>Force</b>, <b>Amour</b>. Laisse-le résonner en toi toute la journée.</p>
    </div>
  </div>
</section>

<!-- RITUEL -->
<section id="rituel" class="section">
  <div class="tile reveal">
    <h2>🕯 Rituel du jour</h2>
    <p>Ferme les yeux. Respire 4‑4‑6. Répète ton mot sacré 3× matin et soir. Laisse la vibration œuvrer.</p>
  </div>
</section>

<footer>© Ex Materia — Sanctuaire de lumière. Tout est Un.</footer>
<a class="fab" href="#livre">Livre du Tout</a>

<!-- ============ SCRIPTS ============ -->
<script>
/* --- STARFIELD performant --- */
const sC = document.getElementById('stars'), nC = document.getElementById('nebula');
const sctx = sC.getContext('2d'), nctx = nC.getContext('2d');
let W,H,pts=[];
function resizeStar(){
  W = sC.width = nC.width = innerWidth;
  H = sC.height = nC.height = innerHeight;
  pts = Array.from({length: Math.min(420, Math.floor(W*H/6000))}, () => ({
    x: Math.random()*W, y: Math.random()*H, z: Math.random()*1.5 + .2, a: Math.random()*0.6+0.2
  }));
  const g = nctx.createRadialGradient(W*.5, H*-.1, 50, W*.5, H*.2, Math.max(W,H));
  g.addColorStop(0,'rgba(36,53,255,.12)'); g.addColorStop(.35,'rgba(36,53,255,.06)'); g.addColorStop(1,'rgba(0,0,0,0)');
  nctx.clearRect(0,0,W,H); nctx.fillStyle=g; nctx.fillRect(0,0,W,H);
}
addEventListener('resize', resizeStar, {passive:true}); resizeStar();
let t=0; (function loop(){
  t+=.6; sctx.clearRect(0,0,W,H);
  for(const p of pts){
    const x = (p.x + t*p.z*0.2) % W;
    const y = (p.y + Math.sin((p.x+t)*0.001)*6*p.z + H) % H;
    sctx.globalAlpha = p.a; sctx.fillStyle = '#fff'; sctx.fillRect(x,y,p.z,p.z);
  }
  requestAnimationFrame(loop);
})();

/* --- Reveal on scroll --- */
const io = new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('show')}),{threshold:.14});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

/* --- Timeline d’illustrations synchronisée --- 
   Modifie ici tes timecodes (en secondes) et les cibles.
   Si un <audio> avec src "assets/voix_du_tout.mp3" est présent et en lecture,
   la timeline se cale dessus. Sinon, elle défile seule. */
const stage = document.getElementById('stage');
const slides = Array.from(stage.querySelectorAll('img,video'));
const checkpoints = [
  {t:0,    i:0},   // 0s -> slide 0 (ex: marionnette)
  {t:9,    i:1},   // 9s -> slide 1 (ex: cosmos)
  {t:18,   i:2},   // 18s -> slide 2 (ex: flux lumineux)
  // {t:27, i:3},  // ajoute si tu as d'autres visuels
];
function showSlide(i){
  slides.forEach((s,idx)=>s.classList.toggle('active', idx===i));
}
showSlide(0);

let audio = document.querySelector('audio[src="assets/voix_du_tout.mp3"]');
let startTS = null, rafId=null;
function tick(ts){
  if(!startTS) startTS = ts;
  const elapsed = (ts - startTS)/1000;
  let t = audio && !audio.paused ? audio.currentTime : elapsed;
  // trouve la dernière checkpoint <= t
  for(let k=checkpoints.length-1;k>=0;k--){
    if(t >= checkpoints[k].t){ showSlide(checkpoints[k].i); break; }
  }
  rafId = requestAnimationFrame(tick);
}
rafId = requestAnimationFrame(tick);

// Si l'audio joue, on recale en cas de seek/pause
if(audio){
  ['play','seeked','timeupdate'].forEach(ev=>audio.addEventListener(ev,()=>{startTS=null}));
}

/* FIN SCRIPTS */
</script>
</body>
</html>
